{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [


        


        {
            "type": "node",
            "request": "launch",
            "name": "Debug Jest Tests",
            "program": "${workspaceFolder}/node_modules/.bin/jest",
            "args": [
                "--runInBand"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "env": {
                "INFINITE_NECK_VERBOSE": "2",
                "INFINITE_NECK_SONG": "",
                "INFINITE_NECK_SONGLIST": "tests/test-song-list-harsh-test.json"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/infinite-neck.js"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug generate-interface.js",
            "program": "${workspaceFolder}/bin/namespacer/generate-interface.js",
            "cwd": "${workspaceFolder}/bin/namespacer",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug PlanRunner.js",
            "program": "${workspaceFolder}/bin/namespacer/PlanRunner.js",
            "cwd": "${workspaceFolder}/bin/namespacer",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "node",
            "outputCapture": "std",
            "env": {
                "NO_COLOR": "1"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug FindMain.js",
            "program": "${workspaceFolder}/bin/namespacer/FindMain.js",
            "args": ["--suite=0", "--dir=data/src"],
            "cwd": "${workspaceFolder}/bin/namespacer",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "node",
            "outputCapture": "std",
            "env": {
                "NO_COLOR": "0"
            }
        }
    ]
}